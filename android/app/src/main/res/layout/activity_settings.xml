<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f172a"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="#f8fafc"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1e293b"
        android:padding="16dp"
        android:layout_marginBottom="16dp">
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Security"
            android:textColor="#3b82f6"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <Switch
            android:id="@+id/switch_app_lock"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Require Authentication"
            android:textColor="#f8fafc"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp"/>
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Locks the app with your device's Fingerprint, Face, or PIN."
            android:textColor="#94a3b8"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <Switch
            android:id="@+id/switch_haptic"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Minimal Haptic Feedback"
            android:textColor="#f8fafc"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp"/>
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Provides a subtle vibration when interacting with buttons (e.g., adding transactions)."
            android:textColor="#94a3b8"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>
            
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1e293b"
        android:padding="16dp"
        android:layout_marginBottom="16dp">
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Storage"
            android:textColor="#3b82f6"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_clear_recorded_data"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Clear Recorded Data"
            android:backgroundTint="#0f172a"
            android:textColor="#f8fafc"
            android:layout_marginBottom="8dp"
            android:gravity="left|center_vertical"
            android:paddingHorizontal="16dp"/>

        <Button
            android:id="@+id/btn_clear_all_data"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Clear All App Data"
            android:backgroundTint="#0f172a"
            android:textColor="#ef4444"
            android:gravity="left|center_vertical"
            android:paddingHorizontal="16dp"/>
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clearing all data will restart the app and show the onboarding tutorial again."
            android:textColor="#94a3b8"
            android:textSize="12sp"
            android:layout_marginTop="8dp"/>
            
    </LinearLayout>

</LinearLayout>
