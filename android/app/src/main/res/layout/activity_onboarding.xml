<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f172a"
    android:padding="24dp"
    android:gravity="center">

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out">

        <!-- Step 1: Welcome -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            
            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_launcher_foreground"
                android:layout_marginBottom="32dp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome to Expense Tracker Pro"
                android:textColor="#f8fafc"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The ultimate tool to track your spending and achieve your financial goals."
                android:textColor="#94a3b8"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="48dp"/>
                
            <Button
                android:id="@+id/btn_tutorial_next"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Take the Tour"
                android:backgroundTint="#3b82f6"
                android:textColor="#ffffff"
                android:layout_marginBottom="16dp"/>
                
            <Button
                android:id="@+id/btn_tutorial_skip"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Skip Tutorial"
                android:background="@null"
                android:textColor="#3b82f6"/>
        </LinearLayout>

        <!-- Step 2: Name (Mandatory) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What should we call you?"
                android:textColor="#f8fafc"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We need this to personalize your experience."
                android:textColor="#94a3b8"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>
                
            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter your name"
                android:textColorHint="#475569"
                android:textColor="#ffffff"
                android:background="#1e293b"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="32dp"
                android:inputType="textPersonName"/>
                
            <Button
                android:id="@+id/btn_name_next"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Next"
                android:backgroundTint="#3b82f6"
                android:textColor="#ffffff"
                android:enabled="false"/>
        </LinearLayout>

        <!-- Step 3: Budget (Optional) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set a Monthly Budget"
                android:textColor="#f8fafc"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This helps you stay on track. You can change it later."
                android:textColor="#94a3b8"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>
                
            <EditText
                android:id="@+id/et_budget"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="e.g. 1000"
                android:textColorHint="#475569"
                android:textColor="#ffffff"
                android:background="#1e293b"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="32dp"
                android:inputType="numberDecimal"/>
                
            <Button
                android:id="@+id/btn_finish"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Get Started"
                android:backgroundTint="#10b981"
                android:textColor="#ffffff"
                android:layout_marginBottom="16dp"/>
                
            <Button
                android:id="@+id/btn_budget_skip"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Skip This Step"
                android:background="@null"
                android:textColor="#94a3b8"/>
        </LinearLayout>

    </ViewFlipper>

</LinearLayout>
